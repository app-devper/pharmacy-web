# vite-plugin-pwa@1.2.0 declares peer vite "^3..^7" but we're on vite 8.
# The plugin actually runs fine on v8 — vite's plugin API is stable across
# that range and PWA build/generateSW still work (verified). Upstream is
# tracking v8 support; until then we tell npm to accept this peer mismatch
# rather than requiring every dev to remember `--legacy-peer-deps`.
legacy-peer-deps=true
